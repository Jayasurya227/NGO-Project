{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "./dist",
    "paths": {
      "@ngo/database": ["../database/src/client.ts"],
      "@ngo/auth": ["../auth/src/index.ts"],
      "@ngo/auth/encryption": ["../auth/src/encryption.ts"],
      "@ngo/agents/utils/embeddings": ["../agents/src/utils/embeddings.ts"],
      "@ngo/types": ["../types/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}